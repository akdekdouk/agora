datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String?
  businessName String
  description  String?
  category     String    // "shop" | "artisan" | "restaurant" | ...
  city         String
  address      String?
  exactAddress String?   // full address as typed/reverse-geocoded
  lat          Float?    // GPS latitude
  lng          Float?    // GPS longitude
  phone        String?
  logo         String?
  createdAt    DateTime  @default(now())
  offers       Offer[]
  products     Product[]
  reviews      Review[]
}

model Offer {
  id          String    @id @default(cuid())
  title       String
  description String
  photo       String?
  bannerKey   String?   // key into /public/banners/{bannerKey}.jpg
  discount    Int       // percentage
  maxClaims   Int?      // null = unlimited
  category    String?   // inherited from merchant or overridden
  validFrom   DateTime
  validTo     DateTime
  deletedAt   DateTime? // soft delete
  createdAt   DateTime  @default(now())
  merchant    User      @relation(fields: [merchantId], references: [id])
  merchantId  String
  claims      Claim[]
}

model Product {
  id              String         @id @default(cuid())
  name            String
  description     String
  images          String         // JSON array of paths
  originalPrice   Float
  discountedPrice Float
  category        String?
  createdAt       DateTime       @default(now())
  merchant        User           @relation(fields: [merchantId], references: [id])
  merchantId      String
  claims          ProductClaim[]
}

model Consumer {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String   @default("")
  name       String?
  phone      String?
  city       String?
  avatar     String?
  interests  String   @default("[]") // JSON array: ["restaurant","shop","artisan"]
  googleId   String?  @unique
  facebookId String?  @unique
  emailNotifications Boolean @default(true)
  createdAt  DateTime @default(now())
  savedOffers       SavedOffer[]
  savedProducts     SavedProduct[]
  followedMerchants FollowedMerchant[]
  claims            Claim[]
  productClaims     ProductClaim[]
  reviews           Review[]
  notifications     Notification[]
}

model Claim {
  id         String    @id @default(cuid())
  consumer   Consumer  @relation(fields: [consumerId], references: [id])
  consumerId String
  offer      Offer     @relation(fields: [offerId], references: [id])
  offerId    String
  code       String    @unique @default(cuid())
  status     String    @default("active") // "active" | "used" | "expired"
  claimedAt  DateTime  @default(now())
  usedAt     DateTime?
  @@unique([consumerId, offerId])
}

model Review {
  id         String   @id @default(cuid())
  consumer   Consumer @relation(fields: [consumerId], references: [id])
  consumerId String
  merchant   User     @relation(fields: [merchantId], references: [id])
  merchantId String
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())
  @@unique([consumerId, merchantId])
}

model SavedOffer {
  id         String   @id @default(cuid())
  consumer   Consumer @relation(fields: [consumerId], references: [id])
  consumerId String
  offerId    String
  savedAt    DateTime @default(now())
  @@unique([consumerId, offerId])
}

model SavedProduct {
  id         String   @id @default(cuid())
  consumer   Consumer @relation(fields: [consumerId], references: [id])
  consumerId String
  productId  String
  savedAt    DateTime @default(now())
  @@unique([consumerId, productId])
}

model FollowedMerchant {
  id         String   @id @default(cuid())
  consumer   Consumer @relation(fields: [consumerId], references: [id])
  consumerId String
  merchantId String
  followedAt DateTime @default(now())
  @@unique([consumerId, merchantId])
}

model Notification {
  id         String   @id @default(cuid())
  consumer   Consumer @relation(fields: [consumerId], references: [id])
  consumerId String
  type       String   // "NEW_OFFER" | "EXPIRING_SOON" | "STOCK_LOW"
  title      String
  body       String
  link       String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model ProductClaim {
  id          String   @id @default(cuid())
  consumer    Consumer @relation(fields: [consumerId], references: [id])
  consumerId  String
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  code        String   @unique @default(cuid())
  status      String   @default("active") // "active" | "used"
  claimedAt   DateTime @default(now())
  @@unique([consumerId, productId])
}

model PlatformConfig {
  id               String   @id @default("default")
  activeCategories String   @default("[\"restaurant\",\"shop\",\"artisan\",\"beauty\",\"hotel\"]") // JSON array, max 5
  theme            String   @default("orange") // "orange" | "blue" | "green" | "purple" | "rose"
  fontStyle        String   @default("modern") // "modern" | "classic" | "bold"
  backgroundPattern String  @default("vannerie")  // "none" | "vannerie" | "marche" | "losanges" | "lin" | "carrelage"
  updatedAt        DateTime @updatedAt
}
