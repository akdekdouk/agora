datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  businessName String
  description  String?
  category     String    // "shop" | "artisan" | "restaurant"
  city         String
  address      String?
  phone        String?
  logo         String?
  createdAt    DateTime  @default(now())
  offers       Offer[]
  products     Product[]
}

model Offer {
  id          String   @id @default(cuid())
  title       String
  description String
  photo       String?
  discount    Int      // percentage
  validFrom   DateTime
  validTo     DateTime
  createdAt   DateTime @default(now())
  merchant    User     @relation(fields: [merchantId], references: [id])
  merchantId  String
}

model Product {
  id              String   @id @default(cuid())
  name            String
  description     String
  images          String   // JSON array of paths
  originalPrice   Float
  discountedPrice Float
  category        String?
  createdAt       DateTime @default(now())
  merchant        User     @relation(fields: [merchantId], references: [id])
  merchantId      String
}

model Consumer {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  savedOffers       SavedOffer[]
  savedProducts     SavedProduct[]
  followedMerchants FollowedMerchant[]
}

model SavedOffer {
  id         String   @id @default(cuid())
  consumer   Consumer @relation(fields: [consumerId], references: [id])
  consumerId String
  offerId    String
  savedAt    DateTime @default(now())
  @@unique([consumerId, offerId])
}

model SavedProduct {
  id         String   @id @default(cuid())
  consumer   Consumer @relation(fields: [consumerId], references: [id])
  consumerId String
  productId  String
  savedAt    DateTime @default(now())
  @@unique([consumerId, productId])
}

model FollowedMerchant {
  id         String   @id @default(cuid())
  consumer   Consumer @relation(fields: [consumerId], references: [id])
  consumerId String
  merchantId String
  followedAt DateTime @default(now())
  @@unique([consumerId, merchantId])
}
